{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices"
  ],
  "regexManagers": [
    {
      "fileMatch": [
        "^kube/app-of-apps/application_set_apps\\.yaml$"
      ],
      "matchStrings": [
        "repoURL:\\s*(?<registryUrl>\\S+)\\s*\\n\\s*chart:\\s*(?<packageName>\\S+)\\s*\\n\\s*targetRevision:\\s*(?<currentValue>\\S+)"
      ],
      "datasourceTemplate": "helm"
    }
  ]
}
