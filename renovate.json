{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "lockFileMaintenance": {
    "enabled": true
  },
  "nix": {
    "enabled": false
  },
  "extends": [
    "config:best-practices"
  ],
  "enabledManagers": [
    "custom.regex"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": [
        "^kube/app-of-apps/application_set_apps\\.yaml$"
      ],
      "matchStrings": [
        "repoURL:\\s*(?<registryUrl>\\S+)\\s*\\n\\s*chart:\\s*(?<packageName>\\S+)\\s*\\n\\s*targetRevision:\\s*(?<currentValue>\\S+)"
      ],
      "datasourceTemplate": "helm",
      "versioningTemplate": "helm"
    }
  ]
}
