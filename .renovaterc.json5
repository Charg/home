{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:best-practices',
  ],
  labels: [
    'dependencies',
  ],
  timezone: 'America/Los_Angeles',
  // Monday-only branch creation
  schedule: [
    '* * * * 1',
  ],
  lockFileMaintenance: {
    enabled: true,
  },
  nix: {
    enabled: true,
  },
  "pre-commit": {
    enabled: true,
  },
  packageRules: [
    {
      matchFileNames: ['kube/nuc01/app-of-apps/application_set_apps.yaml'],
      groupName: 'nuc01 cluster updates',
      groupSlug: 'nuc01-cluster',
    },
    {
      matchFileNames: ['kube/lookie/app-of-apps/application_set_apps.yaml'],
      groupName: 'lookie cluster updates',
      groupSlug: 'lookie-cluster',
    },
  ],
  customManagers: [
    {
      customType: 'regex',
      managerFilePatterns: [
        '/^kube/[^/]+/app-of-apps/application_set_apps\\.yaml$/',
      ],
      matchStrings: [
        'name:\\s*node-feature-discovery[\\s\\S]*?repoURL:\\s*oci://(?<namespace>\\S+)\\s*\\n\\s*chart:\\s*(?<packageName>node-feature-discovery)\\s*\\n\\s*targetRevision:\\s*(?<currentValue>\\S+)',
      ],
      datasourceTemplate: 'docker',
      packageNameTemplate: '{{namespace}}/{{packageName}}',
    },
    {
      customType: 'regex',
      managerFilePatterns: [
        '/^kube/[^/]+/app-of-apps/application_set_apps\\.yaml$/',
      ],
      matchStrings: [
        'repoURL:\\s*(?<registryUrl>https?://\\S+)\\s*\\n\\s*chart:\\s*(?<packageName>\\S+)\\s*\\n\\s*targetRevision:\\s*(?<currentValue>\\S+)',
      ],
      datasourceTemplate: 'helm',
      versioningTemplate: 'helm',
    },
  ],
}
